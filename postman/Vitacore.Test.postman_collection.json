    {
      "name": "Lots",
      "item": [
        {
          "name": "Get Lots",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/Lots?page=1&pageSize=20&orderBy=CreatedAt&isAsc=false"
          }
        },
        {
          "name": "Get Seed Bid Lot",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/Lots/{{seedBidLotId}}"
          }
        },
        {
          "name": "Get Seed Bid Lot Bids",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/Lots/{{seedBidLotId}}/bids?page=1&pageSize=20&orderBy=CreatedAt&isAsc=false"
          }
        },
        {
          "name": "Generate Manual Lot",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "if (json.items && json.items.length > 0) {",
                  "  pm.collectionVariables.set('generatedLotId', json.items[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"count\": 1,\n  \"title\": \"Postman Generated Mandarin\",\n  \"description\": \"Лот, созданный из Postman для проверки ручной генерации.\",\n  \"imageUrl\": \"https://cdn.example.com/tangerines/postman-generated.png\",\n  \"startPrice\": 130.0,\n  \"buyoutPrice\": 300.0,\n  \"auctionStartAt\": \"2026-04-02T10:00:00Z\",\n  \"auctionEndAt\": \"2026-12-31T10:00:00Z\",\n  \"expirationAt\": \"2027-01-03T10:00:00Z\"\n}"
            },
            "url": "{{baseUrl}}/Lots/generate"
          }
        },
        {
          "name": "Get Generated Lot",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/Lots/{{generatedLotId}}"
          }
        }
      ]
    },
    {
      "name": "Bid Flow",
      "item": [
        {
          "name": "Place First Bid by Bidder 1",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bidder1Token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 150.0\n}"
            },
            "url": "{{baseUrl}}/Lots/{{seedBidLotId}}/bids"
          }
        },
        {
          "name": "Place Second Bid by Bidder 2",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bidder2Token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 200.0\n}"
            },
            "url": "{{baseUrl}}/Lots/{{seedBidLotId}}/bids"
          }
        },
        {
          "name": "Process Outbox After Outbid",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/Jobs/process-outbox"
          }
        }
      ]
    },
    {
      "name": "Buyout Flow",
      "item": [
        {
          "name": "Buyout Lot by Buyer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": "{{baseUrl}}/Lots/{{seedBuyoutLotId}}/buyout"
          }
        },
        {
          "name": "Process Outbox After Buyout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/Jobs/process-outbox"
          }
        },
        {
          "name": "Get Buyout Lot",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/Lots/{{seedBuyoutLotId}}"
          }
        }
      ]
    },
    {
