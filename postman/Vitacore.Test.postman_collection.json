          }
        },
        {
          "name": "Cleanup Expired Lots",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/Jobs/cleanup-expired-lots"
          }
        },
        {
          "name": "Get Expired Spoiled Lot (Expect 404 After Cleanup)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/Lots/{{seedExpiredSpoiledLotId}}"
          }
        }
      ]
    },
